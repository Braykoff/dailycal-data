---
import { Image } from "astro:assets";
import logo from "../assets/site/dclogo-black.png";
import "../styles/global.css";
import { joinWithBase, Link } from "../components/Link";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#4c9ad0" />

    <link rel="icon" href={joinWithBase("/favicon.ico")} />

    {/* Head SEO injection */}
    <slot name="head" />
  </head>
  <body>
    {/* Header */}
    <header class="header">
      <Link href="/">
        <Image src={logo} alt="The Daily Californian" class="logo" />
      </Link>
    </header>

    {/* Content */}
    <slot />

    {/* TODO Footer */}
  </body>
</html>

<style>
  body {
    padding-top: 50px;
    background-color: var(--palette-light-gray);
  }
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: white;
    z-index: 9999;
    border-bottom: 1px solid #d3d3d3;
    transition:
      0.2s background-color ease,
      0.2s border-bottom ease;
  }
  .logo {
    height: 20px;
    width: auto;
  }
</style>
