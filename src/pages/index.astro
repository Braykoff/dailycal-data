---
import PageLayout from "../layouts/PageLayout.astro";
import circleLogo from "../assets/site/dclogo-circle.png";
import { Image } from "astro:assets";
import { Link } from "../components/Link";
---

<PageLayout>
  <div class="content">
    {/* Intro */}
    <div class="intro">
      <Image src={circleLogo} alt="The Daily Californian" class="logo" />
      <div class="description">
        <h1>Data</h1>
        <p>
          Investigative stories, data analysis and graphics by The Daily
          Californian&apos;s Data Team
        </p>
      </div>
    </div>

    {/* Articles */}
    <div class="index">
      <Link href="/article/xyz" className="articleCardLink">
        <div class="articleCard">
          {/* Date */}
          <div class="date">April 16, 2026</div>
          {/* Image */}
          <Image
            src={circleLogo}
            alt="Featured image here"
            class="featuredImage"
          />
          {/* Title */}
          <div class="title">Title here</div>
        </div>
      </Link>
    </div>
  </div>
</PageLayout>

<style>
  .content {
    display: flex;
    width: 100%;
    flex-direction: column;
    align-items: center;
    padding-top: 20px;
    margin: 0 auto;
  }

  /* Intro */
  .intro {
    font-family: Georgia, sans-serif;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
  }

  .intro .logo {
    width: 100px;
    height: auto;
    margin: 0;
  }

  .intro .description {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .intro .description h1 {
    font-size: 40px;
    font-weight: 800;
    margin: 0;
    color: var(--palette-black);
    padding-bottom: 7px;
  }

  .intro .description p {
    margin: 0;
    color: var(--palette-dark-gray);
  }

  /* Articles */
  .index {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
  }

  .articleCardLink {
    text-decoration: none;
  }

  .articleCard {
    display: flex;
    flex-direction: column;
    width: 360px;
    height: 350px;
    margin: 20px;
    font-size: 15px;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    font-family: Georgia, sans-serif;
  }

  .articleCard:hover .title {
    text-decoration: underline;
  }

  .articleCard .date {
    color: var(--palette-gray);
    border-top: 1px solid var(--palette-dark-gray);
    font-weight: 400;
    line-height: normal;
    font-size: 12px;
    padding-bottom: 10px;
    padding-top: 10px;
  }

  .articleCard .featuredImage {
    width: 100%;
    height: 230px;
  }

  .articleCard .title {
    font-weight: 400;
    line-height: normal;
    color: var(--palette-black);
    font-size: 24px;
    text-decoration: none;
  }

  /* Mobile/Desktop specific styling */
  @media (min-width: 1200px) {
    .content {
      width: 1200px;
      align-items: normal;
    }
  }

  @media (max-width: 600px) {
    .articleCard {
      width: 350px;
    }
  }
</style>
