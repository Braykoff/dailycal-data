---
import { joinWithBase } from "./Link";

// Throw if a property is not a valid string
function throwIfNotString(property: string, name: string) {
  if (typeof property !== "string" || property.trim().length === 0) {
    throw new Error(`Seo ${name} property is required to be a string!`);
  }
}

// Convert a date into an ISO date string
function toISODate(value: unknown, name: string): string | undefined {
  if (value === undefined || value === null) return undefined;

  const date = new Date(value as any);

  if (isNaN(date.getTime())) {
    throw new Error(`Seo ${name} must be a valid ISO date!`);
  }

  return date.toISOString();
}

// Make a url path absolute (ie, add https://example.com/ to the front)
function toAbsoluteURL(url: string | undefined): string | undefined {
  if (!url) return undefined;
  if (/^https?:\/\//i.test(url)) return url;
  const site = Astro.site?.origin ?? "";
  // We don't need joinWithBase(...) here because Astro handles bases with image urls for us.
  return `${site}${url}`;
}

// Properties
type PageType = "article" | "website";

const { title, description, canonical, image, pageType, authors, publishDate } = Astro.props as {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  pageType: PageType;
  authors?: string | string[];
  publishDate?: unknown;
};

// Throw if the page type (article or website) is not specified
if (pageType !== "article" && pageType !== "website") {
  throw new Error(`Seo pageType must be "article" or "website", got: ${JSON.stringify(pageType)}`);
}

const isArticle = pageType === "article";

throwIfNotString(title, "title");

const absoluteImage = toAbsoluteURL(image);

// Article-specific processing
const safeAuthors = isArticle
  ? typeof authors === "string"
    ? [authors]
    : Array.isArray(authors)
      ? authors
      : []
  : [];

const safeDate = isArticle ? toISODate(publishDate, "publishDate") : undefined;

if (isArticle && safeAuthors.length === 0) {
  throw new Error("Seo authors property is required for articles!");
}

// JSON-LD type and primary label differ between articles and pages
const schemaType = isArticle ? "Article" : "WebPage";
const ogType = isArticle ? "article" : "website";
---

{/* Default tags */}
<meta charset="utf-8" />
<meta name="robots" content="index, follow" />
<link rel="icon" href={joinWithBase("/favicon.ico")} />

<title>{title}</title>
{description && <meta name="description" content={description} />}
{canonical && <link rel="canonical" href={canonical} />}

{safeDate && <meta property="article:published_time" content={safeDate} />}
{safeAuthors.map((a: string) => <meta property="article:author" content={a} />)}

{/* Open Graph tags */}
<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
{description && <meta property="og:description" content={description} />}
{canonical && <meta property="og:url" content={canonical} />}
{absoluteImage && <meta property="og:image" content={absoluteImage} />}

{/* X (formerly Twitter) tags */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
{absoluteImage && <meta name="twitter:image" content={absoluteImage} />}

{/* JSON-LD structured data */}
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": schemaType,

    ...(isArticle ? { headline: title } : { name: title }),

    ...(description && { description }),

    ...(canonical && { url: canonical }),

    ...(absoluteImage && { image: absoluteImage }),

    ...(safeDate && {
      datePublished: safeDate,
      dateModified: safeDate,
    }),

    ...(safeAuthors.length > 0 && {
      author: safeAuthors.map((name: string) => ({
        "@type": "Person",
        name,
      })),
    }),
  })}
/>
